    <!-- Jenkins → ECR (numbered 7) -->
    <mxCell id="e7" value="7 (Push Image)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C7131F;strokeWidth=2;fontStyle=1;fontSize=9;fontColor=#C7131F;" edge="1" source="pod-jenkins" target="ecr" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ArgoCD → ECR pull (numbered 8) -->
    <mxCell id="e8" value="8 (Pull Image)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C7131F;strokeWidth=2;fontStyle=1;fontSize=9;fontColor=#C7131F;dashed=1;" edge="1" source="pod-argocd" target="ecr" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Legend Box -->
    <mxCell id="legend" value="LEGEND" style="text;html=1;strokeColor=#232F3E;fillColor=#F5F5F5;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
      <mxGeometry x="1160" y="380" width="200" height="170" as="geometry" />
    </mxCell>
    <mxCell id="leg1" value="→ Orange: User Traffic Flow" style="text;html=1;align=left;fontSize=9;fontColor=#FF6B35;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1165" y="400" width="190" height="20" as="geometry" />
    </mxCell>
    <mxCell id="leg2" value="⤳ Green: Outbound Traffic (NAT)" style="text;html=1;align=left;fontSize=9;fontColor=#1A9C3E;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1165" y="425" width="190" height="20" as="geometry" />
    </mxCell>
    <mxCell id="leg3" value="⤳ Blue: K8s Control Plane" style="text;html=1;align=left;fontSize=9;fontColor=#147EBA;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1165" y="450" width="190" height="20" as="geometry" />
    </mxCell>
    <mxCell id="leg4" value="→ Purple: CI/CD (Webhook)" style="text;html=1;align=left;fontSize=9;fontColor=#8C4FFF;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1165" y="475" width="190" height="20" as="geometry" />
    </mxCell>
    <mxCell id="leg5" value="→ Red: Image Push/Pull (ECR)" style="text;html=1;align=left;fontSize=9;fontColor=#C7131F;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1165" y="500" width="190" height="20" as="geometry" />
    </mxCell>
    <mxCell id="leg6" value="🟩 Green Box: Public Subnet&#xa;🟨 Yellow Box: Private Subnet&#xa;🟦 Blue Box: Availability Zone" style="text;html=1;align=left;fontSize=9;fontColor=#232F3E;" vertex="1" parent="1">
      <mxGeometry x="1165" y="525" width="190" height="55" as="geometry" />
    </mxCell>

    <!-- Flow numbers legend -->
    <mxCell id="flow-title" value="TRAFFIC FLOW STEPS" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
      <mxGeometry x="1160" y="570" width="200" height="20" as="geometry" />
    </mxCell>
    <mxCell id="flow-steps" value="1. User sends request to Internet&#xa;2. IGW routes to ALB (public subnet)&#xa;3. ALB forwards to EKS nodes (private)&#xa;4. Nodes use NAT for outbound calls&#xa;5. EKS Control Plane manages nodes&#xa;6. GitHub webhook triggers Jenkins&#xa;7. Jenkins builds &amp; pushes to ECR&#xa;8. ArgoCD pulls image, deploys pods" style="text;html=1;strokeColor=#232F3E;fillColor=#F5F5F5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#232F3E;" vertex="1" parent="1">
      <mxGeometry x="1160" y="595" width="220" height="145" as="geometry" />
    </mxCell>

  </root>
